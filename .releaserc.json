{
  "branches": [
    "main",
    { "name": "next", "prerelease": true },
    { "name": "beta", "prerelease": true }
  ],
  "plugins": [
    [
      "@semantic-release/commit-analyzer",
      {
        "preset": "conventionalcommits",
        "releaseRules": [
          { "type": "feat", "release": "minor" },
          { "type": "fix", "release": "patch" },
          { "type": "perf", "release": "patch" },
          { "type": "refactor", "release": "patch" },
          { "type": "docs", "scope": "readme", "release": "patch" },
          { "type": "chore", "release": false },
          { "type": "test", "release": false },
          { "type": "ci", "release": false },
          { "type": "style", "release": false }
        ]
      }
    ],
    ["@semantic-release/release-notes-generator", { "preset": "conventionalcommits" }],
    ["@semantic-release/changelog", { "changelogFile": "CHANGELOG.md" }],
    [
      "@semantic-release/exec",
      {
        "verifyConditionsCmd": "test -n \"$NUGET_API_KEY\" || (echo 'NUGET_API_KEY is required' && exit 1)",
        "prepareCmd": "dotnet pack src/Norbix.Sdk.Types/Norbix.Sdk.Types.csproj -c Release -p:Version=${nextRelease.version} -o ./packages && dotnet pack src/Norbix.Sdk/Norbix.Sdk.csproj -c Release -p:Version=${nextRelease.version} -o ./packages",
        "publishCmd": "for pkg in ./packages/*.nupkg; do echo \"Pushing $pkg\"; dotnet nuget push \"$pkg\" --api-key \"$NUGET_API_KEY\" --source https://api.nuget.org/v3/index.json --skip-duplicate; done"
      }
    ],
    [
      "@semantic-release/git",
      {
        "assets": ["CHANGELOG.md"],
        "message": "chore(release): ${nextRelease.version} [skip ci]\n\n${nextRelease.notes}"
      }
    ],
    "@semantic-release/github"
  ]
}
