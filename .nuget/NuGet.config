<?xml version="1.0" encoding="utf-8"?>
<configuration>
  <!--
    NuGet uses a hierarchy of NuGet.config files. This repo already has a
    root-level ./nuget.config that controls *restore* sources and mapping.

    This file exists to carry over a useful safety setting from the older
    CodeMash SDK: defaultPushSource, to reduce the risk of accidentally
    pushing to the wrong feed when running `dotnet nuget push` locally.
  -->
  <config>
    <add key="defaultPushSource" value="https://api.nuget.org/v3/index.json" />
  </config>
</configuration>

